# Creo la configuracion de la base de datos de la tienda con XAMPP para el backend

DB_NAME=gaming-jcs-bd  #Variable del nombre de la BBDD
DB_USER=root  #Variable del usuario de la BBDD
BD_PASS=    #Vriable de la contraseña de la BBDD en el XAMPP (Vario ya que no tenemos)
BD_HOST=localhost   #Variable del host de la BBDD
DB_PORT=3306  #Puerto donde esta configurado MySQL